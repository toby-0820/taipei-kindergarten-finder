---
import "../styles/global.css";
import SearchBar from "../components/SearchBar.astro";
import Banner from "../components/Banner.astro";
import ResultList from "../components/ResultList.astro";
import ResultCard from "../components/ResultCard.astro";
import PriorityDetail from "../components/PriorityDetail.astro";
import MapView from "../components/MapView.astro";
---
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>台北幼兒園即時查</title>
    <meta name="description" content="輸入家裡位置或學校名稱，查詢台北市公幼與非營利幼兒園的招生名額、即時報名數與分順位中籤機率。資料每 9 分鐘更新。" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
  </head>
  <body>
    <div class="container">
      <header class="site-header">
        <span class="logo" aria-hidden="true">🏫</span>
        <div>
          <h1>台北幼兒園即時查</h1>
          <p class="muted">公幼 / 非營利 招生即時資訊 · 每 9 分鐘更新</p>
        </div>
      </header>
      <Banner />
      <SearchBar />
      <div class="layout">
        <section class="left"><ResultList /></section>
        <section class="right"><MapView /></section>
      </div>
      <ResultCard />
      <PriorityDetail />
      <footer class="site-footer">
        <p>資料來源：臺北市政府教育局 <a href="https://kid.tp.edu.tw" target="_blank" rel="noopener">kid.tp.edu.tw</a>、<a href="https://npkid.tp.edu.tw" target="_blank" rel="noopener">npkid.tp.edu.tw</a></p>
        <p>本站為非官方資訊整理，最終以官方公告為準。機率為依目前報名/名額即時推算。</p>
      </footer>
    </div>

    <script>
      import { search, getCurrentPosition, lookupSchoolDistrict } from "../lib/api-client";
      import type { SearchResponse, SchoolResult, DistrictInfo } from "../lib/api-client";
      import { fmtKm, fmtPct, fmtTimeAgo } from "../lib/format";
      import { calcByPriorityWithSelf, calcByPriorityWithTwinBind } from "../lib/probability";

      type AnyL = any;
      declare global { interface Window { L: AnyL } }

      type AgeBandKey = "3-5歲班" | "5歲班" | "4歲班" | "3歲班" | "2歲專班";
      type SchoolTypeKey = "public" | "non_profit";
      interface PrioritySel { ageBand: AgeBandKey; priority: number; }

      const state: {
        results: SchoolResult[];
        windowMode: string;
        fetchedAt: number | null;
        publicPriority: PrioritySel | null;
        nonProfitPriority: PrioritySel | null;
        map: AnyL | null;
        markers: AnyL[];
        homeMarker: AnyL | null;
        lastQueryLat: number | null;
        lastQueryLng: number | null;
        districtSchoolNames: Set<string>;  // 國小 names in user's 學區
        districtInfo: DistrictInfo | null;  // last successful address → district lookup
      } = {
        results: [], windowMode: "closed", fetchedAt: null,
        publicPriority: null, nonProfitPriority: null,
        map: null, markers: [], homeMarker: null,
        lastQueryLat: null, lastQueryLng: null,
        districtSchoolNames: new Set<string>(),
        districtInfo: null,
      };

      async function updateDistrictInfo(address: string) {
        try {
          const info: DistrictInfo = await lookupSchoolDistrict(address);
          if (!info.ok || !info.elementarySchools || info.elementarySchools.length === 0) {
            state.districtSchoolNames = new Set();
            state.districtInfo = null;
          } else {
            state.districtSchoolNames = new Set(info.elementarySchools.map((s) => s.name));
            state.districtInfo = info;
          }
        } catch {
          state.districtSchoolNames = new Set();
          state.districtInfo = null;
        }
        renderDistrictPanel();
      }

      function renderDistrictPanel() {
        const el = document.getElementById("district-info")!;
        const info = state.districtInfo;
        if (!info || !info.elementarySchools || info.elementarySchools.length === 0) {
          el.style.display = "none";
          return;
        }
        const publicBadges = info.elementarySchools
          .map((s) => `<span class="district-school">${escapeHtml(s.name)}附幼</span>`)
          .join("");

        // 非營利不分學區,但「同行政區戶籍」於抽籤時優先(順位 8 vs 順位 9 跨區)。
        // 列出同行政區所有非營利,按距離排序;若無位置資訊則照名稱排。
        const npInDistrict = state.results
          .filter((s) => s.type === "non_profit" && s.district === info.sect)
          .sort((a, b) => {
            const da = a.distance_km ?? Infinity;
            const db = b.distance_km ?? Infinity;
            if (da !== db) return da - db;
            return a.name.localeCompare(b.name, "zh-Hant");
          });
        const npLine = npInDistrict.length > 0
          ? `🏫 同行政區非營利（共 ${npInDistrict.length} 家）：` +
            npInDistrict.map((s) => `<span class="district-school np">${escapeHtml(s.name)}</span>`).join("") +
            `<br>`
          : state.results.length > 0
            ? `<span class="muted">（${escapeHtml(info.sect)}目前無非營利幼兒園資料）</span><br>`
            : "";

        el.innerHTML =
          `📍 您的學區資料：<strong>${escapeHtml(info.sect)} ${escapeHtml(info.lie)} ${escapeHtml(info.lin ?? "")}</strong><br>` +
          `🏫 學區內公幼（順位 8 一般依學區）：${publicBadges}<br>` +
          npLine +
          `<span class="muted">公幼附幼於上述國小者列入「學區內」順位 8。非營利幼兒園無學區制,但「同行政區戶籍」於抽籤時優先於跨區（順位 8 vs 順位 9）。資料來自臺北市教育局「學區順位系統」。</span>`;
        el.style.display = "block";
      }

      function isInDistrict(schoolName: string): boolean {
        // A 國小附幼 is in the user's 學區 if its name starts with the 國小 name.
        // E.g. "長春國小" in 學區 → "長春國小附幼" is 學區內.
        for (const n of state.districtSchoolNames) {
          const base = n.replace(/國小$/, "").replace(/國民小學$/, "");
          if (!base) continue;
          if (schoolName.startsWith(base) && schoolName.includes("國小附幼")) return true;
        }
        return false;
      }

      function parsePriority(v: string): PrioritySel | null {
        if (!v) return null;
        // Format: "<bandKey>-<priority>" where bandKey ∈ {35, 5, 4, 3, 2}
        const m = v.match(/^(35|5|4|3|2)-(\d+)$/);
        if (!m) return null;
        const bandMap: Record<string, AgeBandKey> = {
          "35": "3-5歲班",
          "5":  "5歲班",
          "4":  "4歲班",
          "3":  "3歲班",
          "2":  "2歲專班",
        };
        return { ageBand: bandMap[m[1]], priority: parseInt(m[2], 10) };
      }

      function priorityFor(schoolType: SchoolTypeKey): PrioritySel | null {
        return schoolType === "public" ? state.publicPriority : state.nonProfitPriority;
      }

      function isTwinBind(): boolean {
        return (document.getElementById("f-twin-bind") as HTMLInputElement | null)?.checked ?? false;
      }

      // Pick the right "含我" model based on the twin-bind toggle.
      function calcSelf(capacity: number, regs: (number | null)[], selfIdx: number) {
        return isTwinBind()
          ? calcByPriorityWithTwinBind(capacity, regs, selfIdx)
          : calcByPriorityWithSelf(capacity, regs, selfIdx);
      }

      function selfLabelPrefix(): string {
        return isTwinBind() ? "綁籤雙胞胎" : "含我";
      }

      // Display label — D1 now stores accurate labels post full-rescrape.
      // Just add a thin space inside "3-5歲班" for readability.
      function ageBandLabel(_schoolType: SchoolTypeKey, ageBand: string): string {
        if (ageBand === "3-5歲班") return "3-5 歲班";
        return ageBand;
      }

      function priorityToArrayIdx(priority: number): number {
        // Source data: index 0 = 順位1-4 lumped, index N = 順位(N+4) for N>=1
        if (priority <= 4) return 0;
        return priority - 4;
      }

      const locateStatus = document.getElementById("locate-status")!;
      let lastSearch: { lat?: number; lng?: number; address?: string; school?: string } | null = null;

      // Returns a Set of allowed "${type}|${age_band}" combinations.
      // 公幼  3-5歲    → "public|3-5歲班"
      // 公幼  2歲專班  → "public|2歲專班"
      // 非營利 5歲      → "non_profit|5歲班"
      // 非營利 4歲      → "non_profit|4歲班"
      // 非營利 3歲      → "non_profit|3歲班"
      // 非營利 2歲      → "non_profit|2歲專班"
      function getClassFilter(): Set<string> {
        const allowed = new Set<string>();
        const map: Array<[string, string]> = [
          ["f-pub-35", "public|3-5歲班"],
          ["f-pub-2", "public|2歲專班"],
          ["f-np-5", "non_profit|5歲班"],
          ["f-np-4", "non_profit|4歲班"],
          ["f-np-3", "non_profit|3歲班"],
          ["f-np-2", "non_profit|2歲專班"],
        ];
        for (const [id, key] of map) {
          if ((document.getElementById(id) as HTMLInputElement | null)?.checked) allowed.add(key);
        }
        return allowed;
      }

      function classAllowed(allowed: Set<string>, type: string, ageBand: string): boolean {
        return allowed.has(`${type}|${ageBand}`);
      }

      function initMap() {
        const L = window.L;
        state.map = L.map("map-view").setView([25.06, 121.55], 12);
        L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
          attribution: "© OpenStreetMap",
          maxZoom: 19,
        }).addTo(state.map);
      }

      function clearMarkers() {
        if (!state.map) return;
        state.markers.forEach((m) => state.map.removeLayer(m));
        state.markers = [];
        if (state.homeMarker) { state.map.removeLayer(state.homeMarker); state.homeMarker = null; }
      }

      function computeDisplayed(): SchoolResult[] {
        const allowed = getClassFilter();
        const sortMode = (document.getElementById("f-sort") as HTMLSelectElement)?.value ?? "distance";
        const visible = state.results.filter((s) =>
          s.classes.some((c) => classAllowed(allowed, s.type, c.age_band)),
        );
        if (state.lastQueryLat != null) {
          visible.sort((a, b) => (a.distance_km ?? Infinity) - (b.distance_km ?? Infinity));
        }
        if (sortMode === "probability") {
          // Take the nearest 10 schools, then sort those 10 by probability.
          // For each school, look up the user's priority for its type. If
          // user hasn't selected a priority for that type, fall back to
          // 3-5歲班 順位 8 as a sensible default.
          const probOf = (s: SchoolResult): number => {
            const sel = priorityFor(s.type);
            const ageBand: AgeBandKey = sel?.ageBand ?? "3-5歲班";
            const priority = sel?.priority ?? 8;
            const c = s.classes.find((cc) => cc.age_band === ageBand);
            if (!c) return -1;
            const idx = priorityToArrayIdx(priority);
            // When the user has selected a priority for this type+age band,
            // sort by 含我 prob (the realistic post-registration odds), not
            // the as-displayed-now snapshot.
            if (sel != null && c.registrations?.regs != null) {
              const ws = calcSelf(c.capacity, c.registrations.regs, idx);
              return ws.probs[idx] ?? -1;
            }
            const cappedIdx = Math.min(idx, c.probabilities.probs.length - 1);
            return c.probabilities.probs[cappedIdx] ?? -1;
          };
          // `visible` was already sorted by distance ascending above.
          const pool = visible.slice(0, 20);
          pool.sort((a, b) => {
            const diff = probOf(b) - probOf(a);
            if (Math.abs(diff) > 1e-9) return diff;
            return (a.distance_km ?? Infinity) - (b.distance_km ?? Infinity);
          });
          return pool;
        }
        return visible;
      }

      function renderResults() {
        const list = document.getElementById("result-list")!;
        list.innerHTML = "";
        const allowed = getClassFilter();
        const displayed = computeDisplayed();
        if (displayed.length === 0) {
          list.innerHTML = '<div class="empty">無符合條件的園所</div>';
          return;
        }
        const tpl = document.getElementById("result-card-template") as HTMLTemplateElement;
        const detailTpl = document.getElementById("priority-detail-template") as HTMLTemplateElement;
        for (const s of displayed) {
          const classesToShow = s.classes.filter((c) => classAllowed(allowed, s.type, c.age_band));
          const node = tpl.content.cloneNode(true) as DocumentFragment;
          const card = node.querySelector(".card") as HTMLElement;
          card.dataset.schoolId = s.school_id;
          const nameEl = node.querySelector(".name") as HTMLElement;
          nameEl.textContent = s.name;
          if (isInDistrict(s.name)) {
            const badge = document.createElement("span");
            badge.className = "district-badge";
            badge.textContent = "學區內";
            badge.title = "您的住家學區內國小的附幼，列入「學區內」順位 8";
            nameEl.appendChild(document.createTextNode(" "));
            nameEl.appendChild(badge);
          }
          (node.querySelector(".distance") as HTMLElement).textContent = fmtKm(s.distance_km);
          (node.querySelector(".type") as HTMLElement).textContent = s.type === "public" ? "公幼" : "非營利";
          (node.querySelector(".district") as HTMLElement).textContent = s.district;
          (node.querySelector(".address") as HTMLElement).textContent = s.address;

          // Sort classes: 3-5歲班 first, then 2歲專班 (predictable order)
          const orderedClasses = [...classesToShow].sort((a, b) => {
            const order = { "3-5歲班": 0, "2歲專班": 1 };
            return (order[a.age_band] ?? 99) - (order[b.age_band] ?? 99);
          });

          function idxToPriorityLabel(i: number): string {
            return i === 0 ? "順位 1-4（優先入園）" : `順位 ${i + 4}`;
          }

          const classesEl = node.querySelector(".classes") as HTMLElement;
          for (const c of orderedClasses) {
            const row = document.createElement("div");
            row.className = "class-row";
            // Look up the user-selected priority for this school's type.
            const sel = priorityFor(s.type);
            const userPriorityApplies = sel != null && sel.ageBand === c.age_band;
            const probIdx = userPriorityApplies
              ? priorityToArrayIdx(sel!.priority)
              : Math.min(4, c.probabilities.probs.length - 1);
            const cappedIdx = Math.min(probIdx, c.probabilities.probs.length - 1);
            const prob = c.probabilities.probs[cappedIdx];
            const priorityLabel = userPriorityApplies
              ? `第 ${sel!.priority} 順位`
              : `順位 8（一般幼兒）`;

            // "含我" 試算: 只在用戶選了順位、且該班型有報名資料 (open mode) 時計算
            let probDisplay: string;
            const regs = c.registrations?.regs ?? null;
            if (userPriorityApplies && regs != null) {
              const withSelf = calcSelf(c.capacity, regs, probIdx);
              const probSelf = withSelf.probs[probIdx];
              probDisplay = `<span class="muted">原 ${fmtPct(prob)} →</span> <strong class="with-self">${selfLabelPrefix()} ${fmtPct(probSelf)}</strong>`;
            } else {
              probDisplay = fmtPct(prob);
            }

            // "前面順位加總 + 你的順位剩幾個缺額" — sum regs[0..probIdx-1]
            // (everyone in higher priorities), remaining = capacity - that sum.
            let priorContext = "";
            if (regs != null) {
              let higherSum = 0;
              for (let i = 0; i < probIdx && i < regs.length; i++) {
                higherSum += regs[i] ?? 0;
              }
              const remaining = Math.max(0, c.capacity - higherSum);
              priorContext = `<span class="prior-ctx">（前順位共 <strong>${higherSum}</strong> 人，剩 <strong>${remaining}</strong> 位）</span>`;
            }
            row.innerHTML = `<span>${ageBandLabel(s.type, c.age_band)}｜名額 ${c.capacity}${priorContext}</span><span>${priorityLabel} ${probDisplay}</span>`;
            classesEl.appendChild(row);
          }

          const detailEl = node.querySelector(".priority-detail") as HTMLElement;
          const detailNode = detailTpl.content.cloneNode(true) as DocumentFragment;
          const tablesEl = detailNode.querySelector(".priority-tables") as HTMLElement;

          for (const c of orderedClasses) {
            const sel2 = priorityFor(s.type);
            const selfApplies = sel2 != null && sel2.ageBand === c.age_band;
            const highlightIdx = selfApplies ? priorityToArrayIdx(sel2!.priority) : -1;
            const regs2 = c.registrations?.regs ?? null;
            const withSelf = (selfApplies && regs2 != null)
              ? calcSelf(c.capacity, regs2, highlightIdx)
              : null;
            // Extend row count so the user's selected priority row shows
            // even if it's past the table's natural length (e.g. 順位 9
            // when source data only has up to 順位 8).
            const rowCount = withSelf
              ? Math.max(c.probabilities.probs.length, highlightIdx + 1)
              : c.probabilities.probs.length;

            const table = document.createElement("table");
            table.className = "priority-table";

            const caption = document.createElement("caption");
            caption.textContent = `${ageBandLabel(s.type, c.age_band)}　名額 ${c.capacity}　總登記 ${c.registrations?.total ?? "—"} 人`;
            table.appendChild(caption);

            const thead = document.createElement("thead");
            thead.innerHTML = withSelf
              ? `<tr><th>順位</th><th class="num">報名數</th><th class="num">中籤機率</th><th class="num">含我機率</th></tr>`
              : `<tr><th>順位</th><th class="num">報名數</th><th class="num">中籤機率</th></tr>`;
            table.appendChild(thead);

            const tbody = document.createElement("tbody");
            for (let i = 0; i < rowCount; i++) {
              const prob = c.probabilities.probs[i] ?? null;
              const reg = c.registrations?.regs?.[i] ?? null;
              const tr = document.createElement("tr");
              if (highlightIdx === i) tr.className = "highlight";
              const probClass = prob === 1 ? "prob-100" : (prob === 0 ? "prob-0" : "");
              const baseCells = `<td>${idxToPriorityLabel(i)}</td><td class="num">${reg ?? "—"}</td><td class="num ${probClass}">${fmtPct(prob)}</td>`;
              if (withSelf) {
                const ps = withSelf.probs[i] ?? null;
                const psClass = ps === 1 ? "prob-100" : (ps === 0 ? "prob-0" : "");
                tr.innerHTML = `${baseCells}<td class="num ${psClass}">${fmtPct(ps)}</td>`;
              } else {
                tr.innerHTML = baseCells;
              }
              tbody.appendChild(tr);
            }
            table.appendChild(tbody);
            tablesEl.appendChild(table);
          }
          detailEl.appendChild(detailNode);

          const toggle = node.querySelector(".toggle-detail") as HTMLButtonElement;
          toggle.addEventListener("click", () => {
            detailEl.style.display = detailEl.style.display === "none" ? "block" : "none";
            toggle.textContent = detailEl.style.display === "none" ? "展開順位明細 ▾" : "收起 ▴";
          });

          card.addEventListener("mouseenter", () => highlightOnMap(s.school_id));
          list.appendChild(node);
        }
      }

      function renderMap(queryLat: number | null, queryLng: number | null) {
        if (!state.map) return;
        const L = window.L;
        clearMarkers();
        if (queryLat != null && queryLng != null) {
          state.homeMarker = L.marker([queryLat, queryLng])
            .addTo(state.map)
            .bindPopup("您的位置");
        }
        const visible = computeDisplayed();
        const bounds: [number, number][] = [];
        for (const s of visible) {
          if (s.lat == null || s.lng == null) continue;
          const color = s.type === "public" ? "#2563eb" : "#ea580c"; // 公幼藍 / 非營利橘
          const m = L.circleMarker([s.lat, s.lng], { radius: 6, color, fillColor: color, fillOpacity: 0.7, weight: 2 })
            .addTo(state.map)
            .bindPopup(buildPopup(s));
          (m as any).schoolId = s.school_id;
          // Also open popup on mouseover (Leaflet default is click only).
          m.on("mouseover", function (this: any) { this.openPopup(); });
          state.markers.push(m);
          bounds.push([s.lat, s.lng]);
        }
        if (queryLat != null && queryLng != null) bounds.push([queryLat, queryLng]);
        // When user has a location, zoom into the neighbourhood (~1 km radius).
        // Otherwise (school-name search), fit all markers.
        if (queryLat != null && queryLng != null) {
          state.map.setView([queryLat, queryLng], 15);
        } else if (bounds.length > 1) {
          state.map.fitBounds(bounds, { padding: [40, 40] });
        }
      }

      function buildPopup(s: SchoolResult): string {
        const typeLabel = s.type === "public" ? "公幼" : "非營利";
        const lines: string[] = [
          `<strong>${escapeHtml(s.name)}</strong>`,
          `<span class="muted">${typeLabel}・${escapeHtml(s.district)}・${fmtKm(s.distance_km)}</span>`,
        ];
        const sel = priorityFor(s.type);
        const allowed = getClassFilter();
        for (const c of s.classes) {
          if (!classAllowed(allowed, s.type, c.age_band)) continue;
          const applies = sel != null && sel.ageBand === c.age_band;
          const probIdx = applies
            ? priorityToArrayIdx(sel!.priority)
            : Math.min(4, c.probabilities.probs.length - 1);
          const cappedIdx = Math.min(probIdx, c.probabilities.probs.length - 1);
          const prob = c.probabilities.probs[cappedIdx];
          const label = applies ? `第 ${sel!.priority} 順位` : `順位 8（一般）`;
          const regs = c.registrations?.regs ?? null;
          let priorCtx = "";
          if (regs != null) {
            let higherSum = 0;
            for (let i = 0; i < probIdx && i < regs.length; i++) higherSum += regs[i] ?? 0;
            const remaining = Math.max(0, c.capacity - higherSum);
            priorCtx = `<br><span style="color:#6b7280;font-size:0.9em">前順位共 ${higherSum} 人，剩 ${remaining} 位</span>`;
          }
          if (applies && regs != null) {
            const ws = calcSelf(c.capacity, regs, probIdx);
            const ps = ws.probs[probIdx];
            lines.push(`${ageBandLabel(s.type, c.age_band)}｜名額 ${c.capacity}｜${label} <span class="muted">原 ${fmtPct(prob)} →</span> <strong>${selfLabelPrefix()} ${fmtPct(ps)}</strong>${priorCtx}`);
          } else {
            lines.push(`${ageBandLabel(s.type, c.age_band)}｜名額 ${c.capacity}｜${label} <strong>${fmtPct(prob)}</strong>${priorCtx}`);
          }
        }
        return lines.join("<br>");
      }

      function escapeHtml(s: string): string {
        return s.replace(/[&<>"']/g, (c) => (
          { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]!
        ));
      }

      function highlightOnMap(id: string) {
        for (const m of state.markers) {
          if ((m as any).schoolId === id) m.openPopup();
        }
      }

      function updateBanner() {
        const banner = document.getElementById("banner")!;
        const text = document.getElementById("banner-text")!;
        const age = document.getElementById("data-age")!;
        if (state.windowMode === "closed") {
          banner.style.display = "block";
          text.textContent = "目前非報名期。以下為招生名額公告，報名數與機率將於開放後顯示。";
        } else if (state.windowMode === "drawn") {
          banner.style.display = "block";
          text.textContent = "今年抽籤已完成。以下顯示最終資料。";
        } else {
          banner.style.display = "none";
        }
        age.textContent = `資料更新於 ${fmtTimeAgo(state.fetchedAt)}`;
      }

      // Request all schools so client-side sort by distance / probability works
      // against the full dataset, not just top-20-by-distance.
      const FULL_LIMIT = 300;

      async function runSearchByLocation() {
        locateStatus.classList.remove("error");
        locateStatus.textContent = "正在取得您的位置…";
        let pos;
        try {
          pos = await getCurrentPosition();
        } catch (e: any) {
          locateStatus.classList.add("error");
          locateStatus.textContent = "無法取得位置：" + (e?.message ?? "請允許瀏覽器存取定位");
          return;
        }
        locateStatus.textContent = `已取得位置：${pos.lat.toFixed(4)}, ${pos.lng.toFixed(4)}`;
        lastSearch = { lat: pos.lat, lng: pos.lng };
        // 定位搜尋沒地址,清掉前次學區資料避免錯誤殘留
        state.districtInfo = null;
        state.districtSchoolNames = new Set();
        await runSearch({ lat: pos.lat, lng: pos.lng, limit: FULL_LIMIT });
      }

      async function runSearchByAddress() {
        const addr = (document.getElementById("address-input") as HTMLInputElement).value.trim();
        if (!addr) return;
        locateStatus.classList.remove("error");
        locateStatus.textContent = `正在查詢地址：${addr}…`;
        lastSearch = { address: addr };
        // Fire both lookups in parallel.
        const [_, __] = await Promise.all([
          runSearch({ address: addr, limit: FULL_LIMIT }),
          updateDistrictInfo(addr),
        ]);
      }

      async function runSearchBySchool() {
        const name = (document.getElementById("school-input") as HTMLInputElement).value.trim();
        if (!name) return;
        lastSearch = { school: name };
        state.districtInfo = null;
        state.districtSchoolNames = new Set();
        await runSearch({ school: name, limit: FULL_LIMIT });
      }

      async function runSearch(params: { lat?: number; lng?: number; address?: string; school?: string; limit?: number }) {
        try {
          const resp: SearchResponse = await search(params);
          if (resp.geocode_status === "not_found") {
            locateStatus.classList.add("error");
            locateStatus.textContent = resp.hint ?? "找不到此地址";
            return;
          }
          if (resp.location_status === "outside_taipei") {
            locateStatus.classList.remove("error");
            locateStatus.textContent = `提示：此位置在台北市範圍外，以下為台北市最近的園所。`;
          } else if (params.address && resp.query_lat != null) {
            locateStatus.textContent = `已定位：${resp.query_lat.toFixed(4)}, ${resp.query_lng!.toFixed(4)}`;
          }
          state.results = resp.results;
          state.windowMode = resp.window_mode;
          state.fetchedAt = resp.fetched_at;
          state.lastQueryLat = resp.query_lat;
          state.lastQueryLng = resp.query_lng;
          renderResults();
          renderMap(resp.query_lat, resp.query_lng);
          renderDistrictPanel();
          updateBanner();
        } catch (e) {
          console.error(e);
          alert("查詢失敗，請稍後再試");
        }
      }

      // Bootstrap: load Leaflet, then wire events
      const leafletScript = document.createElement("script");
      leafletScript.src = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js";
      leafletScript.crossOrigin = "";
      leafletScript.onload = () => initMap();
      document.head.appendChild(leafletScript);

      document.getElementById("locate-btn")!.addEventListener("click", runSearchByLocation);
      document.getElementById("address-btn")!.addEventListener("click", runSearchByAddress);
      document.getElementById("address-input")!.addEventListener("keydown", (e) => {
        if ((e as KeyboardEvent).key === "Enter") runSearchByAddress();
      });
      document.getElementById("school-btn")!.addEventListener("click", runSearchBySchool);
      document.getElementById("school-input")!.addEventListener("keydown", (e) => {
        if ((e as KeyboardEvent).key === "Enter") runSearchBySchool();
      });
      document.getElementById("f-priority-public")!.addEventListener("change", () => {
        const v = (document.getElementById("f-priority-public") as HTMLSelectElement).value;
        state.publicPriority = parsePriority(v);
        renderResults();
        renderMap(state.lastQueryLat, state.lastQueryLng);
      });
      document.getElementById("f-priority-np")!.addEventListener("change", () => {
        const v = (document.getElementById("f-priority-np") as HTMLSelectElement).value;
        state.nonProfitPriority = parsePriority(v);
        renderResults();
        renderMap(state.lastQueryLat, state.lastQueryLng);
      });

      document.getElementById("f-sort")!.addEventListener("change", () => {
        renderResults();
        renderMap(state.lastQueryLat, state.lastQueryLng);
      });

      document.getElementById("f-twin-bind")!.addEventListener("change", () => {
        renderResults();
        renderMap(state.lastQueryLat, state.lastQueryLng);
      });

      // Re-render when any (type × age) checkbox toggles
      for (const id of ["f-pub-35", "f-pub-2", "f-np-5", "f-np-4", "f-np-3", "f-np-2"]) {
        document.getElementById(id)!.addEventListener("change", () => {
          if (state.results.length > 0) {
            renderResults();
            renderMap(state.lastQueryLat, state.lastQueryLng);
          }
        });
      }

      // Auto-refresh every 9 minutes (matching the cron's 3-batch rotation
      // cycle on Workers Free).
      setInterval(() => {
        if (state.results.length > 0 && lastSearch) {
          runSearch({ ...lastSearch });
        }
      }, 540_000);
    </script>

    <style>
      .site-header { margin-bottom: 1rem; display: flex; align-items: center; gap: 0.75rem; }
      .site-header .logo { font-size: 3rem; flex-shrink: 0; line-height: 1; }
      .site-header h1 { margin: 0; }
      .site-header p { margin: 0.25rem 0 0; }
      .site-header .byline { color: var(--muted); font-size: 0.65em; font-weight: 400; margin-left: 0.5rem; }
      .layout { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
      @media (max-width: 768px) {
        .layout { display: flex; flex-direction: column; }
        .layout .right { order: -1; }   /* map first */
        .layout .left { order: 0; }     /* results below */
      }
      .site-footer { margin-top: 2rem; padding-top: 1rem; border-top: 1px solid var(--border); color: var(--muted); font-size: 0.85rem; }
    </style>
  </body>
</html>
